{
  "name": "roleplay-novel-studio",
  "version": "0.1.0",
  "private": true,
  "description": "利用多 AI 扮演法写小说的本地创作工作台",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "dev:web": "vite --config client/vite.config.js",
    "build:web": "vite build --config client/vite.config.js",
    "test": "node scripts/agent-e2e.js --suite smoke",
    "test:e2e:agent": "node scripts/agent-e2e.js --suite agent",
    "test:e2e:writing": "node scripts/agent-e2e.js --suite writing",
    "test:e2e:runtime": "node scripts/agent-e2e.js --suite runtime",
    "test:e2e:all": "node scripts/agent-e2e.js --suite all"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@arco-design/web-react": "^2.66.15",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@vitejs/plugin-react": "^6.0.2",
    "js-tiktoken": "^1.0.21",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "vite": "^8.0.14"
  }
}
